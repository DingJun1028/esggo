{
  "hosting": {
    "site": "esggooriginal",
    "public": ".next/standalone",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "ESG GO",
        "supportEmail": "dingjunhong1028@gmail.com"
      }
    }
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs20",
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/.next/**",
      "**/build/**"
    ],
    "predeploy": [
      "npm run build"
    ]
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}
