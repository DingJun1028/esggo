{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*",
        "./lib/*",
        "./packages/*",
        "./app/*",
        "./components/*",
        "./hooks/*",
        "./*"
      ],
      "@dataconnect/generated": [
        "./dataconnect/generated/index.ts"
      ],
      "playwright": [
        "./node_modules/playwright/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "lib/**/*",
    "app/**/*",
    "components/**/*",
    "hooks/**/*",
    "dataconnect/**/*",
    "types/**/*",
    "next.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/stories",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}