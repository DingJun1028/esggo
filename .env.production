# ==============================================================================
# ESGGO 善向永續 | 全域環境變數配置範例 (.env.example)
# ==============================================================================

# --- 1. 核心變數 (Core Variables) ---
# 確保前後端雙向資料庫連線以及 AI 原生服務能正常啟動

# [Supabase] 資料庫與身分驗證
NEXT_PUBLIC_SUPABASE_URL=https://test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# [Firebase] 客戶端配置 / Firebase Data Connect
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=esg-sunshine.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=esg-sunshine
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=esg-sunshine.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_ga_id

# [AI 與代理服務] (AI & Agent Services)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key_optional
BROWSER_USE_API_KEY=your_browser_use_cloud_v3_api_key

# --- 2. 擴充與整合變數 (Integration Variables) ---
# 若您開啟了 Omni-Skills 或是跨平台智庫的整合服務，請加入以下變數

# [NCBDB] 主權展示與 MCP (Nocodebackend DataBase)
NCBDB_BASE_URL=https://www.nocodebackend.com/
NCBDB_PROJECT_ID=your_ncbdb_project_id
NCBDB_API_TOKEN=your_ncbdb_api_token
NCBDB_WEBHOOK_SECRET=your_ncbdb_webhook_secret

# [第三方工具庫]
NOTION_API_KEY=your_notion_api_key
SPACE_ID=your_notion_space_id
FIRECRAW_API_KEY=your_firecrawl_api_key
RESEND_API_KEY=your_resend_api_key
AITABLE_API_KEY=your_aitable_api_key
STRAICO_API_KEY=your_straico_api_key
BOOSTSPACE_TOKEN=your_boostspace_token

# [系統底盤設定]
NEXT_PUBLIC_APP_URL=https://esggo.vercel.app
NEXT_PUBLIC_SITE_URL=https://esggo.vercel.app
OMNIAGENT_API_URL=http://127.0.0.1:8642
NEXT_PUBLIC_OMNIAGENT_GATEWAY_URL=http://127.0.0.1:8642

# [Swap-DeFi-TEST-UMES-ONLINE] 交易所整合 (DeFi Integration)
# 交易所測試環境 API 金鑰
SWAP_DEFI_API_KEY=your_test_api_key
# 交易所認證令牌
SWAP_DEFI_TOKEN=your_test_token
# 交易所 API 端點
SWAP_DEFI_ENDPOINT=https://test-umes.online/api/v1

# --- 3. Slack OmniAgent Gateway ---
# 按照 Hermes Slack 文件完成 Slack App 建立後填入以下變數
# 參考：https://hermesagent.xyz/messaging-platforms/slack
#
# Bot User OAuth Token (xoxb-)，在 OAuth & Permissions 取得
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App-Level Token (xapp-)，在 Settings > Socket Mode 取得
SLACK_APP_TOKEN=xapp-your-app-token-here
# Slack Signing Secret，在 Settings > Basic Information 取得
SLACK_SIGNING_SECRET=your-signing-secret-here
# 授權使用者的 Slack Member ID (逗號分隔)
SLACK_ALLOWED_USERS=U01ABC2DEF3,U02XYZ456GH
# 預設推播頻道 ID (C 開頭)，在頻道詳細資訊底部取得
SLACK_HOME_CHANNEL=C01234567890
SLACK_HOME_CHANNEL_NAME=general
