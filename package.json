{
  "name": "esggo-omnimcp",
  "version": "1.0.0",
  "description": "OmniMCP integration for ESGGO platform with master authorization",
  "main": "dist/server.js",
  "scripts": {
    "build": "next build && node scripts/copy-standalone-assets.js",
    "start": "node -r dotenv/config .next/standalone/server.js",
    "dev": "ts-node server.ts",
    "lint": "next lint",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "omni:setup": "npx tsx scripts/setup_all_tables.ts",
    "omni:setup:dry": "npx tsx scripts/setup_all_tables.ts --dry-run",
    "omni:setup:notes": "npx tsx scripts/setup_notes_tasks_table.ts",
    "omni:setup:intel": "npx tsx scripts/setup_daily_intelligence_table.ts",
    "omni:setup:esg-risk": "npx tsx scripts/setup_esg_risk_audit_table.ts",
    "omni:setup:compliance": "npx tsx scripts/setup_compliance_engine_table.ts",
    "omni:setup:governance": "npx tsx scripts/setup_governance_audit_table.ts",
    "omni:setup:supplier": "npx tsx scripts/setup_supplier_integrity_table.ts",
    "omni:setup:vault": "npx tsx scripts/setup_vault_omni_table.ts",
    "omni:setup:swarm": "npx tsx scripts/setup_swarm_consensus_table.ts",
    "omni:scan": "npx tsx scripts/fnns-scanner.ts",
    "list-stitch-projects": "npx tsx scripts/list-stitch-projects.ts",
    "prepare": "node -e \"try { require('child_process').execSync('husky') } catch (e) {}\""
  },
