{
  "display_information": {
    "name": "ESGGO OmniAgent",
    "description": "ESG GO 善向永續 — 5T 協議驅動的 ESG 治理 AI 閘道",
    "background_color": "#020617"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "ESGGO OmniAgent",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/esg-five-t",
        "url": "https://your-domain.com/api/slack/command",
        "description": "觸發 5T 協議評分報告",
        "usage_hint": "company",
        "should_escape": false
      },
      {
        "command": "/omni",
        "url": "https://your-domain.com/api/slack/command",
        "description": "傳遞自然語言指令至 OmniAgent",
        "usage_hint": "command",
        "should_escape": false
      },
      {
        "command": "/esg-status",
        "url": "https://your-domain.com/api/slack/command",
        "description": "查詢 OmniAgent 閘道運行狀態",
        "usage_hint": "check",
        "should_escape": false
      },
      {
        "command": "/esg-alert",
        "url": "https://your-domain.com/api/slack/command",
        "description": "手動推播合規警報至頻道",
        "usage_hint": "message",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "users:read",
        "files:read",
        "files:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im",
        "message.channels",
        "message.groups"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
